{
  "expo": {
    "name": "Rhome",
    "slug": "rhome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rhome",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rhome.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rhome.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F1020",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "useNextNotificationsApi": true
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#141414",
          "dark": {
            "backgroundColor": "#141414"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Feather.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#ff6b5b",
          "sounds": []
        }
      ],
      ["@sentry/react-native", { "organization": "rhome-app", "project": "rhome-app" }],
      "expo-audio"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0c68666d-6abb-46e3-b540-7725b6e6c977"
      }
    },
    "owner": "alwaysrhome",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0c68666d-6abb-46e3-b540-7725b6e6c977"
    }
  }
}
